{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information including roles and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "teacher", "parent", "student"] },
        "phone": { "type": "string" },
        "preferredLanguage": { "type": "string", "enum": ["Swahili", "English"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName", "role", "email"]
    },
    "Student": {
      "title": "Student",
      "description": "Student academic and personal records.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "dob": { "type": "string", "format": "date" },
        "nectaRegNumber": { "type": "string" },
        "form": { "type": "string" },
        "stream": { "type": "string" },
        "parentUid": { "type": "string" },
        "studentUid": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Transferred", "Graduated"] },
        "enrolledAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "gender", "dob", "form"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Daily attendance logs for students.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Present", "Absent", "Late"] },
        "reason": { "type": "string" },
        "term": { "type": "integer", "enum": [1, 2, 3] },
        "recordedBy": { "type": "string" }
      },
      "required": ["studentId", "date", "status", "term"]
    },
    "Grade": {
      "title": "Academic Grade",
      "description": "Grades for subjects across terms.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "term": { "type": "integer", "enum": [1, 2, 3] },
        "year": { "type": "integer" },
        "category": { "type": "string", "enum": ["Test", "Mid-Term", "Final"] },
        "recordedBy": { "type": "string" }
      },
      "required": ["studentId", "subject", "score", "term", "year"]
    },
    "Fee": {
      "title": "Fee Payment",
      "description": "Record of fee payments including mobile money integrations.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "category": { "type": "string", "enum": ["Tuition", "Uniform", "Books", "Transport", "Other"] },
        "term": { "type": "integer", "enum": [1, 2, 3] },
        "paymentMethod": { "type": "string", "enum": ["M-Pesa", "Tigo Pesa", "Airtel Money", "HaloPesa", "Bank", "Cash"] },
        "transactionId": { "type": "string" },
        "recordedBy": { "type": "string" }
      },
      "required": ["studentId", "amount", "date", "category", "term"]
    },
    "TeachingAssignment": {
      "title": "Teaching Assignment",
      "description": "Links a teacher to a specific subject, form, and stream.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "subject": { "type": "string" },
        "form": { "type": "string" },
        "stream": { "type": "string" },
        "academicYear": { "type": "number" }
      },
      "required": ["teacherId", "subject", "form", "stream", "academicYear"]
    },
    "PermissionRequest": {
      "title": "Permission Request",
      "description": "Student requests for leave or emergency permission.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentUid": { "type": "string" },
        "studentName": { "type": "string" },
        "type": { "type": "string", "enum": ["Sick", "Emergency", "Other"] },
        "reason": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "requestedAt": { "type": "string", "format": "date-time" },
        "reviewedBy": { "type": "string" },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "adminComment": { "type": "string" }
      },
      "required": ["studentId", "studentUid", "studentName", "type", "reason", "startDate", "endDate", "status", "requestedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles managed by UID."
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student records."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Global attendance records indexed by date and student."
    },
    "/grades/{gradeId}": {
      "schema": "Grade",
      "description": "Student grades."
    },
    "/fees/{feeId}": {
      "schema": "Fee",
      "description": "Fee payment records."
    },
    "/assignments/{assignmentId}": {
      "schema": "TeachingAssignment",
      "description": "Teacher subject/class assignments."
    },
    "/permission_requests/{requestId}": {
      "schema": "PermissionRequest",
      "description": "Student leave/permission requests."
    }
  }
}
